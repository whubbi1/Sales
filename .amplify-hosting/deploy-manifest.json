{
  "version": 1,
  "routes": [
    {
      "path": "/_next/static/*",
      "target": { "kind": "Static" },
      "headers": { "cache-control": "public, max-age=31536000, immutable" }
    },
    {
      "path": "/*",
      "target": { "kind": "Compute", "src": "default" }
    }
  ],
  "computeResources": [
    {
      "name": "default",
      "runtime": "nodejs20.x",
      "entrypoint": "server.js"
    }
  ],
  "framework": {
    "name": "next",
    "version": "16.2.9"
  }
}