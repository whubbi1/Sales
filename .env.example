# .env.example — Copiez en .env et remplissez les valeurs
# Ne jamais committer le fichier .env !

# ─── AWS ──────────────────────────────────────────────────────────────────────
AWS_REGION=eu-west-1
AWS_ACCESS_KEY_ID=votre_access_key
AWS_SECRET_ACCESS_KEY=votre_secret_key

# ─── Base de données ──────────────────────────────────────────────────────────
# En local : postgresql://user:password@localhost:5432/wcomply_db
# En prod  : récupéré automatiquement depuis AWS SSM
DATABASE_URL=postgresql://wcomply_admin:VOTRE_MOT_DE_PASSE@localhost:5432/wcomply_db

# ─── Microsoft Azure / Outlook ────────────────────────────────────────────────
# Créer une App Registration sur https://portal.azure.com
MS_TENANT_ID=votre_tenant_id_azure
MS_CLIENT_ID=votre_client_id_azure
MS_CLIENT_SECRET=votre_client_secret_azure

# Permissions nécessaires dans Azure AD :
# - Mail.Read, Mail.Send
# - Calendars.Read, Calendars.ReadWrite
# - User.Read

# ─── Azure OpenAI / Copilot ────────────────────────────────────────────────────
AZURE_OPENAI_ENDPOINT=https://votre-resource.openai.azure.com/
AZURE_OPENAI_API_KEY=votre_azure_openai_key
AZURE_OPENAI_DEPLOYMENT=gpt-4

# ─── AWS Cognito ──────────────────────────────────────────────────────────────
COGNITO_USER_POOL_ID=eu-west-1_XXXXXXXX
COGNITO_CLIENT_ID=votre_cognito_client_id
COGNITO_REGION=eu-west-1

# ─── Application ──────────────────────────────────────────────────────────────
ENVIRONMENT=development
SECRET_KEY=votre_secret_jwt_key_32_caracteres_minimum

# ─── Frontend (Next.js — préfixe NEXT_PUBLIC_ obligatoire) ───────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_COGNITO_USER_POOL_ID=eu-west-1_XXXXXXXX
NEXT_PUBLIC_COGNITO_CLIENT_ID=votre_cognito_client_id
NEXT_PUBLIC_COGNITO_DOMAIN=https://auth-wcomply-prod.auth.eu-west-1.amazoncognito.com
