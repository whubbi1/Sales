{
  "family": "whubbi-backend",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "512",
  "memory": "1024",
  "executionRoleArn": "arn:aws:iam::351007427901:role/whubbi-ecs-task-execution-role",
  "taskRoleArn": "arn:aws:iam::351007427901:role/whubbi-ecs-task-execution-role",
  "containerDefinitions": [
    {
      "name": "whubbi-backend",
      "image": "351007427901.dkr.ecr.eu-west-1.amazonaws.com/whubbi-backend:v9",
      "portMappings": [{"containerPort": 8000, "hostPort": 8000, "protocol": "tcp"}],
      "essential": true,
      "environment": [
        {"name": "DATABASE_URL", "value": "postgresql://whubbi_admin:MotDePasseSecurise123%21@whubbi-postgres-dev.ct4k6k6uiegz.eu-west-1.rds.amazonaws.com:5432/whubbi_db?ssl=disable"}
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/whubbi-backend",
          "awslogs-region": "eu-west-1",
          "awslogs-stream-prefix": "ecs"
        }
      }
    }
  ]
}
